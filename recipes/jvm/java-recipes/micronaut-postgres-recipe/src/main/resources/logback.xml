<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%white([%t]) %highlight(%-5level) %magenta(%c{1}) - %yellow(%m) %n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
    <logger name="io.micronaut" level="INFO"/>
</configuration>
