      ],
      "configure": "mongodb {\n  MongodbSystemOptions(\n    configureExposedConfiguration = { cfg ->\n      listOf(\"spring.data.mongodb.uri=${cfg.connectionString}\")\n    }\n  )\n}",
      "testDsl": "mongodb {\n  shouldGet<MyDoc>(objectId = \"doc-id\", collection = \"orders\") {\n    it.status shouldBe \"CREATED\"\n  }\n}"
    },
