{
  "$schema_note": "Generated by hooks/macros.py from docs/_data/*.yaml. Edit YAML files, not this JSON.",
  "frameworks": {
    "ktor": {
      "label": "Ktor",
      "gradle": [
        "com.trendyol:stove-ktor"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.ktor.ktor"
      ],
      "runner": "ktor(\n  runner = { params -> {pkg}.run(params, wait = false) },\n  withParameters = listOf(\"server.port=8080\")\n)"
    },
    "micronaut": {
      "label": "Micronaut",
      "gradle": [
        "com.trendyol:stove-micronaut"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.micronaut.micronaut"
      ],
      "runner": "micronaut(\n  runner = { params -> {pkg}.run(params) },\n  withParameters = listOf(\"micronaut.server.port=8080\")\n)"
    },
    "quarkus": {
      "label": "Quarkus (no bridge)",
      "gradle": [
        "com.trendyol:stove-quarkus"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.quarkus.quarkus"
      ],
      "runner": "quarkus(\n  runner = { params -> {pkg}.main(params) },\n  withParameters = listOf(\"quarkus.http.port=8080\")\n)"
    },
    "spring-boot": {
      "label": "Spring Boot",
      "gradle": [
        "com.trendyol:stove-spring"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.springBoot"
      ],
      "runner": "springBoot(\n  runner = { params ->\n    {pkg}.run(params) {\n      addTestDependencies {\n        // bean<TestSystemKafkaInterceptor<*, *>>(isPrimary = true)\n        // bean { StoveSerde.jackson.anyByteArraySerde() }\n      }\n    }\n  },\n  withParameters = listOf(\"server.port=8080\")\n)"
    }
  },
  "runtimes": {
    "container": {
      "label": "Docker image (container mode)",
      "gradle": [
        "com.trendyol:stove-container"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.container.containerApp"
      ],
      "runner": "containerApp {\n  ContainerAppOptions(\n    image = \"ghcr.io/your-org/your-app:latest\",\n    exposedPorts = listOf(8080),\n    readiness = ReadinessStrategy.HttpGet(path = \"/health\")\n  )\n}"
    },
    "go": {
      "label": "Go binary (goApp)",
      "gradle": [
        "com.trendyol:stove-process"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.process.goApp"
      ],
      "runner": "goApp {\n  GoAppOptions(\n    sourcePath = \"../app\",\n    readiness = ReadinessStrategy.HttpGet(url = \"http://localhost:8080/health\")\n  )\n}"
    },
    "process": {
      "label": "Host binary (process mode)",
      "gradle": [
        "com.trendyol:stove-process"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.process.processApp"
      ],
      "runner": "processApp {\n  ProcessAppOptions(\n    binaryPath = \"./build/app\",\n    readiness = ReadinessStrategy.HttpGet(url = \"http://localhost:8080/health\")\n  )\n}"
    },
    "provided": {
      "label": "Already-deployed app",
      "gradle": [],
      "imports": [
        "com.trendyol.stove.testing.e2e.providedApplication"
      ],
      "runner": "providedApplication {\n  ProvidedApplicationOptions(\n    readiness = ReadinessStrategy.HttpGet(url = \"https://staging.myapp.com/health\")\n  )\n}"
    }
  },
  "tests": {
    "junit": {
      "label": "JUnit 5",
      "gradle": [
        "com.trendyol:stove-extensions-junit"
      ],
      "extensionLine": null,
      "classBase": "BaseE2ETest",
      "classImport": null,
      "sample": "class SampleE2ETest : BaseE2ETest() {\n  @Test\n  fun `end-to-end flow works`() = runTest {\n    stove {\n{body}\n    }\n  }\n}"
    },
    "kotest": {
      "label": "Kotest (recommended)",
      "gradle": [
        "com.trendyol:stove-extensions-kotest"
      ],
      "extensionLine": "StoveKotestExtension()",
      "classBase": "FunSpec",
      "classImport": "io.kotest.core.spec.style.FunSpec",
      "sample": "class SampleE2ETest : FunSpec({\n  test(\"end-to-end flow works\") {\n    stove {\n{body}\n    }\n  }\n})"
    }
  },
  "systems": {
    "sys.bridge": {
      "label": "Bridge (DI access)",
      "family": "interaction",
      "gradle": [],
      "imports": [
        "com.trendyol.stove.testing.e2e.bridge"
      ],
      "configure": "bridge()",
      "testDsl": "bridge {\n  using<MyRepository> { repo ->\n    repo.findAll() shouldHaveSize 1\n  }\n}"
    },
    "sys.cassandra": {
      "label": "Cassandra",
      "family": "database",
      "gradle": [
        "com.trendyol:stove-cassandra"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.cassandra.*"
      ],
      "configure": "cassandra {\n  CassandraSystemOptions(\n    configureExposedConfiguration = { cfg ->\n      listOf(\"cassandra.contact-points=${cfg.contactPoints}\")\n    }\n  )\n}",
      "testDsl": "cassandra { shouldExecute(\"SELECT now() FROM system.local\") }"
    },
    "sys.couchbase": {
      "label": "Couchbase",
      "family": "database",
      "gradle": [
        "com.trendyol:stove-couchbase"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.couchbase.*"
      ],
      "configure": "couchbase {\n  CouchbaseSystemOptions(\n    bucketName = \"testbucket\",\n    configureExposedConfiguration = { cfg ->\n      listOf(\n        \"couchbase.hosts=${cfg.hostsWithPort}\",\n        \"couchbase.username=${cfg.username}\",\n        \"couchbase.password=${cfg.password}\"\n      )\n    }\n  )\n}",
      "testDsl": "couchbase {\n  shouldGet<MyDoc>(\"doc-id\") {\n    it.field shouldBe \"value\"\n  }\n}"
    },
    "sys.elasticsearch": {
      "label": "Elasticsearch",
      "family": "database",
      "gradle": [
        "com.trendyol:stove-elasticsearch"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.elasticsearch.*"
      ],
      "configure": "elasticsearch {\n  ElasticsearchSystemOptions(\n    configureExposedConfiguration = { cfg ->\n      listOf(\"elasticsearch.url=${cfg.url}\")\n    }\n  )\n}",
      "testDsl": "elasticsearch {\n  shouldGet<MyDoc>(index = \"orders\", key = \"id\") {\n    it.field shouldBe \"x\"\n  }\n}"
    },
    "sys.grpc-mock": {
      "label": "gRPC Mock",
      "family": "mock",
      "gradle": [
        "com.trendyol:stove-grpc-mock"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.grpc.mock.*"
      ],
      "configure": "grpcMock {\n  GrpcMockSystemOptions(port = 0)\n}",
      "testDsl": "grpcMock {\n  mockUnary(\n    serviceName = \"com.acme.InventoryService\",\n    methodName = \"Reserve\",\n    response = ReserveResponse.newBuilder().setSuccess(true).build()\n  )\n}"
    },
    "sys.grpc": {
      "label": "gRPC client",
      "family": "interaction",
      "gradle": [
        "com.trendyol:stove-grpc"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.grpc.*"
      ],
      "configure": "grpc {\n  GrpcSystemOptions(host = \"localhost\", port = 9090)\n}",
      "testDsl": "grpc {\n  wireClient<MyServiceClient>().getItem(GetItemRequest(id = \"1\")).status shouldBe \"OK\"\n}"
    },
    "sys.http": {
      "label": "HTTP client",
      "family": "interaction",
      "gradle": [
        "com.trendyol:stove-http"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.http.httpClient",
        "com.trendyol.stove.testing.e2e.http.HttpClientSystemOptions"
      ],
      "configure": "httpClient {\n  HttpClientSystemOptions(baseUrl = \"http://localhost:8080\")\n}",
      "testDsl": "http {\n  get<String>(\"/hello\") { body ->\n    body shouldContain \"hello\"\n  }\n}"
    },
    "sys.kafka": {
      "label": "Kafka",
      "family": "messaging",
      "gradle": [
        "com.trendyol:stove-kafka"
      ],
      "imports": [
        "com.trendyol.stove.testing.e2e.messaging.kafka.*",
        "com.trendyol.stove.testing.e2e.serialization.StoveSerde",
        "kotlin.time.Duration.Companion.seconds"
      ],
      "configure": "kafka {\n  KafkaSystemOptions(\n    serde = StoveSerde.jackson.anyByteArraySerde(),\n    configureExposedConfiguration = { cfg ->\n      listOf(\n        \"spring.kafka.bootstrap-servers=${cfg.bootstrapServers}\",\n        \"spring.kafka.producer.properties.interceptor.classes=${cfg.interceptorClass}\",\n        \"spring.kafka.consumer.properties.interceptor.classes=${cfg.interceptorClass}\"\n      )\n    }\n  )\n}",
      "testDsl": "kafka {\n  shouldBePublished<Map<String, Any>> {\n    actual[\"type\"] == \"created\"\n  }\n}"
    },
    "sys.mongodb": {
      "label": "MongoDB",
      "family": "database",
      "gradle": [
        "com.trendyol:stove-mongodb"
      ],
      "imports": [
